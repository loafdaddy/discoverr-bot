# Discoverr environment template
# Copy to .env and fill in your values:  cp .env.example .env
# Run with Docker:  docker compose up -d --build
# Docs: README.md · SETUP.md · docs/ARCHITECTURE.md

# --- Required ---
TMDB_API_KEY=your_tmdb_api_key_here
SEERR_URL=https://your-seerr-domain.example
SEERR_USERNAME=Discoverr
SEERR_PASSWORD=your_discoverr_seerr_password_here
DISCORD_TOKEN=your_discord_bot_token_here

# Watch region for TMDb discovery / providers
# Codes: AU, US, GB, CA, NZ, DE, FR, JP, KR, MX, BR, IN, CN, ES, IT
# Names also work: USA, United States, Australia, United Kingdom
WATCH_REGION=AU

# Comma-separated TMDb watch-provider names for your region
STREAMING_SERVICES="Netflix,Disney Plus,Amazon Prime Video,Apple TV Plus,Stan,BINGE,Paramount Plus"

# Discord channel IDs (leave blank to disable a category)
MOVIE_OF_DAY_CHANNEL_ID=your_channel_id_here
TV_OF_DAY_CHANNEL_ID=your_channel_id_here
TRENDING_CHANNEL_ID=your_channel_id_here
NEW_RELEASES_CHANNEL_ID=your_channel_id_here
STREAMING_CHANNEL_ID=your_channel_id_here
HIDDEN_GEMS_CHANNEL_ID=your_channel_id_here

# --- Optional ---
# Post once immediately when the process starts (smoke tests only)
POST_ON_START=false

# When to post (timezone-aware). Pick ONE approach:
#
# 1) Simple daily time (24-hour HH:MM) — easiest
POST_TIME=09:00
#
# 2) Or hour + minute separately (used if POST_TIME is unset)
# POST_HOUR=9
# POST_MINUTE=0
#
# 3) Or a full cron expression (overrides POST_TIME / POST_HOUR if set)
# CRON_SCHEDULE=0 9 * * *
#
# Timezone for the schedule (IANA name). TIMEZONE is accepted as an alias.
TZ=Australia/Melbourne

# TMDb request shaping
TMDB_LANGUAGE=en-AU
TMDB_PAGES=4

# Suggestion cooldown (days). Posted titles are skipped until this expires.
HISTORY_TTL_DAYS=90

# Global quality floors (categories may raise these further)
MIN_RATING=6.2
MIN_VOTES=80

# If Seerr media lookup fails, skip the title instead of recommending it
SEERR_FAIL_CLOSED=true
