# Discoverr environment template
# Secrets only for new installs. Existing 2.x .env files keep working in 3.0
# without edits (channels/schedule/tuning still read from env if settings.json
# is missing). Prefer data/settings.json for new operator knobs — see SETUP.md.
#
# Copy:  cp .env.example .env
#        cp settings.example.json data/settings.json   # new installs
# Run:   docker compose up -d --build

# --- Discord ---
DISCORD_TOKEN=your_discord_bot_token_here

# --- TMDb ---
TMDB_API_KEY=your_tmdb_api_key_here

# --- Seerr ---
SEERR_URL=https://your-seerr-domain.example
SEERR_USERNAME=Discoverr
SEERR_PASSWORD=your_discoverr_seerr_password_here

# ---------------------------------------------------------------------------
# Migration bridge (optional): non-secret knobs below still work if you have not
# created data/settings.json yet. Prefer settings.json for new installs so
# upgrades do not require re-pasting channels / schedule / tuning into .env.
# ---------------------------------------------------------------------------

# WATCH_REGION=AU
# STREAMING_SERVICES="Netflix,Disney Plus,Amazon Prime Video,Apple TV Plus,Stan,BINGE,Paramount Plus"
# MOVIE_OF_DAY_CHANNEL_ID=
# TV_OF_DAY_CHANNEL_ID=
# TRENDING_CHANNEL_ID=
# NEW_RELEASES_CHANNEL_ID=
# STREAMING_CHANNEL_ID=
# HIDDEN_GEMS_CHANNEL_ID=
# POST_ON_START=false
# POST_TIME=09:00
# TZ=Australia/Melbourne
# TMDB_LANGUAGE=en-AU
# TMDB_PAGES=4
# HISTORY_TTL_DAYS=90
# MIN_RATING=6.2
# MIN_VOTES=80
# SEERR_FAIL_CLOSED=true
